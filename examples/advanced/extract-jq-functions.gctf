--- ENDPOINT ---
shop.OrderService/GetOrder

--- REQUEST ---
{
  "order_id": 123
}

--- RESPONSE ---
{
  "created_at": "2024-01-15T10:30:00Z",
  "items": [
    {
      "name": "Item 1",
      "price": 10.0,
      "qty": 2
    },
    {
      "name": "Item 2",
      "price": 25.0,
      "qty": 1
    }
  ],
  "order_id": 123,
  "status": 200,
  "tax_rate": 0.08
}

--- EXTRACT ---

--- ASSERTS ---
// Verify extractions
.order_id == 123
.item_count == 2
@len(.item_names) == 2
.status_label == "OK"
